@model Project_Keystone.Models.ProjectTask

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>ProjectTask</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TaskName" class="control-label"></label>
                <input asp-for="TaskName" class="form-control" />
                <span asp-validation-for="TaskName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TaskDesc" class="control-label"></label>
                <input asp-for="TaskDesc" class="form-control" />
                <span asp-validation-for="TaskDesc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TaskPriority" class="control-label"></label>
                <select asp-for="TaskPriority" class ="form-control" asp-items="ViewBag.TaskPriority"></select>
            </div>
            <div class="form-group">
                <label asp-for="TaskStatus" class="control-label"></label>
                <select asp-for="TaskStatus" class ="form-control" asp-items="ViewBag.TaskStatus"></select>
            </div>
            <div class="form-group">
                <label asp-for="TaskTimeStamp" class="control-label"></label>
                <input asp-for="TaskTimeStamp" class="form-control" />
                <span asp-validation-for="TaskTimeStamp" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TaskDueDate" class="control-label"></label>
                <input asp-for="TaskDueDate" class="form-control" />
                <span asp-validation-for="TaskDueDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TaskProjectID" class="control-label"></label>
                <select asp-for="TaskProjectID" class ="form-control" asp-items="ViewBag.TaskProjectID"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
