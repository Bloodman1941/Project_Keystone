@model IEnumerable<Project_Keystone.Models.Role>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.RoleName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RoleDesc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RolePermCreate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RolePermEdit)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RolePermDelete)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RolePermInvite)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RolePermEditRoles)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.RoleName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RoleDesc)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RolePermCreate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RolePermEdit)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RolePermDelete)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RolePermInvite)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RolePermEditRoles)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.RoleID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.RoleID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.RoleID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
